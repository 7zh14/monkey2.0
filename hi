<!DOCTYPE html>
<html>
<head>
    <title>Dynamic Movie Search</title>
    <style>
        body { font-family: sans-serif; padding: 20px; text-align: center; }
        input { padding: 10px; width: 250px; border: 1px solid #ccc; border-radius: 4px; }
        button { padding: 10px 20px; cursor: pointer; background: #007bff; color: white; border: none; border-radius: 4px; }
        button:hover { background: #0056b3; }
        .container { margin-top: 20px; }
    </style>
</head>
<body>

    <h2>Enter Movie ID</h2>
    <input type="text" id="movieIdInput" placeholder="Enter ID (e.g., 1078605)">
    <button onclick="updateIframe()">Load Movie</button>

    <div class="container">
        <iframe 
            id="moviePlayer"
            src="about:blank" 
            width="100%" 
            height="600" 
            frameborder="0" 
            allowfullscreen>
        </iframe>
    </div>

    <script>
        function updateIframe() {
            // 1. Get the value from the input box
            const movieId = document.getElementById('movieIdInput').value;
            
            // 2. Target the iframe
            const iframe = document.getElementById('moviePlayer');
            
            // 3. Build the new URL and set it
            if (movieId.trim() !== "") {
                iframe.src = "https://www.vidking.net/embed/movie/" + movieId;
            } else {
                alert("Please enter a valid ID!");
            }
        }
    </script>

</body>
</html>
